# === App ===
APP_NAME=traffix-backend
APP_VERSION=0.1.0
APP_ENV=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=*

# === ML Model Paths (resolved via backend/ and repo root) ===
LSTM_15M_PATH=../LSTM Training/artifacts/best_lstm_15m.keras
LSTM_2H_PATH=../LSTM Training/artifacts/best_lstm_2h.keras
LSTM_4H_PATH=../LSTM Training/artifacts/best_lstm_4h.keras
LSTM_CONFIG_PATH=../LSTM Training/artifacts/best_config.json
FEAT_SCALER_PATH=../LSTM Training/artifacts/feat_scaler.joblib
TARGET_SCALER_PATH=../LSTM Training/artifacts/target_scalers.joblib
ML_AUTO_LOAD=true
ML_ALLOW_FALLBACK=true
PREDICTION_AUTO_REFRESH=true

# === Data Paths ===
HYBRID_TRAFFIC_DATASET_PATH=../data/data_synthetic/hybrid_traffic_7d.csv
FEATURE_COLUMNS_PATH=../data/data_process/feature_columns.json
DUMMY_DATA_PATH=../data/data_synthetic/hybrid_traffic_7d.csv
PREDICTION_OUTPUT_PATH=../inference/inference_lstm/traffix_lstm_inference_outputs/lstm_prediction_output.csv
PREDICTION_OUTPUT_JSON_PATH=../inference/inference_lstm/traffix_lstm_inference_outputs/lstm_prediction_output.json
YOLO_VEHICLE_COUNT_PATH=../inference/inference_yolo/vehicle_count.csv

# === Simulation ===
SIMULATION_AUTO_START=true
TICK_INTERVAL_SECONDS=2
SIM_INTERSECTIONS=4

# === Weather (BMKG - future block) ===
BMKG_API_URL=https://api.bmkg.go.id/publik/prakiraan-cuaca

# === Camera/YOLO ===
CAMERA_INPUT_ENABLED=false
MAX_CAMERAS=16
CAMERA_METADATA_PATH=../inference_data/data_video/metadata/video_weather_data.csv
CAMERA_VIDEO_ROOT_PATH=../inference_data/data_video/video_input
CAMERA_VIDEO_LIBRARY_URL=https://drive.google.com/drive/folders/1qJQ_B9wZP_kuzXoqaEtjVzBwLJTw3a0g?usp=sharing
